# Backend configuration. Copy to `.env` and adjust as needed.
# Real environment variables take precedence over values in .env.

# Secret used to sign JWT tokens. MUST be a strong, unique value in production.
SECRET_KEY=route53-clone-dev-secret-key-do-not-use-in-production

# JWT signing algorithm.
JWT_ALGORITHM=HS256

# SQLAlchemy database URL.
DATABASE_URL=sqlite:///./route53.db

# Comma-separated list of allowed CORS origins (the frontend URL).
CORS_ORIGINS=http://localhost:3000
